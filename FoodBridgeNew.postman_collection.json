{
  "info": {
    "name": "FoodBridge API New",
    "_postman_id": "new-collection-001",
    "description": "New Postman collection for FoodBridge API with auth token handling and correct phone format",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Registration",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Donor\",\n  \"email\": \"donor@example.com\",\n  \"phone\": \"+911234567890\",\n  \"password\": \"password123\",\n  \"location\": \"Test Location\",\n  \"role\": \"Donor\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "auth", "register"]
        }
      },
      "response": []
    },
    {
      "name": "User Login and Set Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"authToken\", jsonData.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"donor@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Create Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"Veg\",\n  \"quantity\": \"50 servings\",\n  \"location\": \"Sector 62, Noida\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/token",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "token"]
        }
      },
      "response": []
    },
    {
      "name": "Get Available Tokens",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "http://localhost:5000/api/token",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "token"]
        }
      },
      "response": []
    },
    {
      "name": "Claim Token",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "http://localhost:5000/api/token/:id/claim",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "token", ":id", "claim"]
        }
      },
      "response": []
    },
    {
      "name": "Get Donor Tokens",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "http://localhost:5000/api/token/donor-dashboard",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "token", "donor-dashboard"]
        }
      },
      "response": []
    }
  ]
}
